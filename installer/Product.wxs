<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <?define ProductName = "RBPO Antivirus" ?>
  <?define Manufacturer = "RBPO" ?>
  <?define Version = "1.0.0.0" ?>

  <Product Id="A1B2C3D4-E5F6-7890-1234-567890ABCDEF" Name="$(var.ProductName)" Language="1049" Version="$(var.Version)" Manufacturer="$(var.Manufacturer)" UpgradeCode="B5A1C8F2-3E4D-4A5B-9C7D-8E0F1A2B3C4D">
    <Package InstallerVersion="500" Compressed="yes" InstallScope="perMachine" Platform="x64" />
    <MajorUpgrade DowngradeErrorMessage="A newer version is already installed." />
    <Media Id="1" Cabinet="product.cab" EmbedCab="yes" />

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="RBPO" />
      </Directory>
    </Directory>

    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />
    <UIRef Id="WixUI_Minimal" />
    <WixVariable Id="WixUILicenseRtf" Value="installer\license.rtf" />

    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
      <Component Id="RBPOAppExe" Guid="39D16D67-9969-4793-A887-FCE2BC8E8FAC">
        <File Id="RBPOAppExeFile" Name="rbpo-app.exe" Source="$(var.SourceDir)\rbpo-app.exe" KeyPath="yes" />
      </Component>
      <Component Id="RBPOServiceExe" Guid="007ADAA1-33D5-4DC4-8BDB-4BBEDB80403B">
        <File Id="RBPOServiceExeFile" Name="rbpo-service.exe" Source="$(var.SourceDir)\rbpo-service.exe" KeyPath="yes" />
        <ServiceInstall Id="RBPOServiceInstall" Name="RBPOService" DisplayName="RBPO Service"
                        Type="ownProcess" Start="auto" ErrorControl="normal"
                        Account="NT AUTHORITY\SYSTEM" />
        <ServiceControl Id="RBPOServiceControl" Name="RBPOService"
                        Start="none" Stop="both" Remove="uninstall" Wait="yes" />
      </Component>
      <Component Id="AvDbDefault" Guid="B2E3F4A5-C6D7-8901-2345-678901234567">
        <File Id="AvDbDefaultBin" Name="avdb.default.bin" Source="$(var.SourceDir)\avdb.default.bin" KeyPath="yes" />
      </Component>
      <Component Id="AvDbDefaultManifest" Guid="C3D4E5B6-A7F8-9012-3456-789012345678">
        <File Id="AvDbDefaultManifestFile" Name="avdb.default.manifest" Source="$(var.SourceDir)\avdb.default.manifest" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <Feature Id="ProductFeature" Title="RBPO Antivirus" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
      <MergeRef Id="VCRedist" />
    </Feature>

    <DirectoryRef Id="TARGETDIR">
      <Merge Id="VCRedist" SourceFile="$(var.VCRedistPath)" DiskId="1" Language="0" />
    </DirectoryRef>
  </Product>
</Wix>
